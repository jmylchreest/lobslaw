# lobslaw/.env — secrets + bootstrap values.
# Loaded BEFORE config.toml, so anything referenced via `env:NAME` in
# the TOML picks up its value from here. Outer shell env wins — if
# you already export FOO=x before running lobslaw, a FOO here is ignored.

# ── LLM provider API keys ──────────────────────────────────────────
# Match to your [[compute.providers]] api_key_ref = "env:OPENROUTER_API_KEY"
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
# OPENAI_API_KEY=sk-REPLACE_ME
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Declare providers entirely via env (container-first deployments) ──
# Shape: LOBSLAW_PROVIDER_<LABEL>_<FIELD>=value
# Label matching is CASE-INSENSITIVE: LOBSLAW_PROVIDER_FAST_* and
# LOBSLAW_PROVIDER_fast_* both target a `label = "fast"` provider.
# Env values override matching fields in config.toml's
# [[compute.providers]]; new labels are appended.
#
# LOBSLAW_PROVIDER_fast_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
# LOBSLAW_PROVIDER_fast_MODEL=gpt-4o-mini
# LOBSLAW_PROVIDER_fast_API_KEY=env:OPENROUTER_API_KEY
# LOBSLAW_PROVIDER_fast_TRUST_TIER=public
# LOBSLAW_PROVIDER_fast_CAPABILITIES=code,fast
#
# LOBSLAW_PROVIDER_local_ENDPOINT=http://localhost:11434/v1/chat/completions
# LOBSLAW_PROVIDER_local_MODEL=llama3.1
# LOBSLAW_PROVIDER_local_TRUST_TIER=local

# ── Memory at-rest encryption key (required when memory function is on) ──
# Match to [memory.encryption.key_ref] = "env:LOBSLAW_MEMORY_KEY"
# Generate one: `openssl rand -base64 32`
LOBSLAW_MEMORY_KEY=REPLACE_ME_32_BYTES_BASE64

# ── Telegram (Phase 6e — lands shortly) ────────────────────────────
# TELEGRAM_BOT_TOKEN=1234567890:AAREPLACE_ME
# TELEGRAM_WEBHOOK_SECRET=REPLACE_ME_RANDOM

# ── Quoting examples the parser supports ───────────────────────────
# PLAIN=nospaces
# QUOTED="value with spaces and escapes \n \t"
# LITERAL='literal ${NOT_EXPANDED} characters'
# EXPORT_OK=works  # `export EXPORT_OK=works` is also tolerated

# Copy to .env and fill in values. docker-compose reads .env
# automatically from this directory.

# Hostname → raft.ServerID. Set per-node in multi-node deployments
# (lobslaw-1, lobslaw-2, lobslaw-3). The cert-init container signs
# the cert for this exact value, and the runtime validates the cert
# CN matches at boot, so changing this requires a fresh cert.
LOBSLAW_HOSTNAME=lobslaw-1

# Memory FSM encryption key — 32 bytes base64. Generate with:
#   head -c 32 /dev/urandom | base64
LOBSLAW_MEMORY_KEY=

# LLM provider key. Naming follows the LOBSLAW_<LABEL>_API_KEY
# pattern keyed off the [[compute.providers]].label in config.toml.
LOBSLAW_FAST_API_KEY=

# Telegram bot token (only if [[gateway.channels]] declares a
# telegram channel). Empty disables.
LOBSLAW_TELEGRAM_BOT_TOKEN=

# Host port mappings. Override if you run multiple stacks side by
# side on one host.
LOBSLAW_CLUSTER_PORT=7443
LOBSLAW_GATEWAY_PORT=8443

# Container timezone (scheduler honours operator timezone for cron).
TZ=UTC

# Override which host file is bind-mounted as /etc/lobslaw/config.toml
# in the container. Default is the in-repo template (./config.toml,
# relative to deploy/docker/). Set to your personal copy to keep the
# repo template clean and your tweaks separate:
#   LOBSLAW_CONFIG_FILE=${HOME}/.config/lobslaw/container.toml
#   LOBSLAW_SOUL_FILE=${HOME}/.config/lobslaw/SOUL.md
# Note: these MUST be container-shaped paths inside the file (e.g.
# /var/lobslaw/data, /workspace) — bare-binary configs reference host
# paths and won't work as-is.
# LOBSLAW_CONFIG_FILE=
# LOBSLAW_SOUL_FILE=

# Log level: debug|info|warn|error. debug enables hashicorp/raft
# trace, the 30s raft cluster snapshot, and per-packet broadcast
# events — verbose but invaluable while bringing a cluster up. Drop
# to info once it's stable.
LOBSLAW_LOG_LEVEL=debug

# Log format: auto|json|text. auto picks json in containers (no TTY)
# and text in interactive terminals. Override to text for human-
# friendly compose logs at the cost of jq-ability.
LOBSLAW_LOG_FORMAT=json
